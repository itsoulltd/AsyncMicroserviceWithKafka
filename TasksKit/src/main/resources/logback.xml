        </encoder>
    </appender>-->

    <!-- -->
    <!-- OFF ERROR WARN INFO DEBUG TRACE -->
    <logger name="com.infoworks" level="INFO"/>

    <!-- -->
    <root level="INFO">
        <!--<appender-ref ref="CONSOLE"/>-->
        <!--<appender-ref ref="FILE"/>-->
        <appender-ref ref="ASYNC-CONSOLE"/>
    </root>
    <!-- -->
</configuration>